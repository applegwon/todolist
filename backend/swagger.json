{
  "openapi": "3.0.3",
  "info": {
    "title": "TodoList API",
    "description": "TodoList 웹 애플리케이션의 REST API 명세서",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "로컬 개발 서버"
    }
  ],
  "tags": [
    {
      "name": "auth",
      "description": "인증 (회원가입, 로그인)"
    },
    {
      "name": "users",
      "description": "사용자 정보 조회 및 수정"
    },
    {
      "name": "categories",
      "description": "카테고리 CRUD"
    },
    {
      "name": "todos",
      "description": "할일 CRUD 및 필터링"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT 액세스 토큰. 로그인 후 발급된 토큰을 사용한다."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "사용자 고유 식별자"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "로그인용 이메일"
          },
          "name": {
            "type": "string",
            "description": "사용자 이름"
          },
          "theme": {
            "type": "string",
            "enum": ["light", "dark"],
            "description": "UI 테마 설정"
          },
          "language": {
            "type": "string",
            "enum": ["ko", "en"],
            "description": "UI 언어 설정"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "계정 생성 시각"
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "카테고리 고유 식별자"
          },
          "name": {
            "type": "string",
            "description": "카테고리 이름"
          },
          "user_id": {
            "type": "integer",
            "nullable": true,
            "description": "소유자 사용자 ID. NULL이면 시스템 공통 기본 카테고리"
          }
        }
      },
      "Todo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "할일 고유 식별자"
          },
          "title": {
            "type": "string",
            "description": "할일 제목"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "할일 상세 설명"
          },
          "start_date": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "시작 일자 (ISO 8601 datetime. 예: '2026-05-27T00:00:00.000Z')"
          },
          "end_date": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "종료 일자 (ISO 8601 datetime. 예: '2026-05-28T00:00:00.000Z')"
          },
          "status": {
            "type": "string",
            "enum": ["미시작", "진행중", "완료"],
            "description": "진행 상태"
          },
          "category_id": {
            "type": "integer",
            "description": "소속 카테고리 ID"
          },
          "user_id": {
            "type": "integer",
            "description": "소유자 사용자 ID"
          },
          "is_overdue": {
            "type": "boolean",
            "description": "기한초과 여부. end_date < 오늘 AND status != 완료 일 때 true"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "할일 생성 시각"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "할일 최종 수정 시각"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "description": "HTTP 상태 코드"
          },
          "message": {
            "type": "string",
            "description": "사용자 친화적 오류 메시지"
          },
          "code": {
            "type": "string",
            "description": "프로그래매틱 오류 코드"
          }
        },
        "required": ["status", "message", "code"]
      }
    }
  },
  "paths": {
    "/api/auth/signup": {
      "post": {
        "tags": ["auth"],
        "summary": "회원가입",
        "description": "이메일, 비밀번호, 이름을 입력하여 새 계정을 생성한다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "name"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "로그인에 사용할 이메일"
                  },
                  "password": {
                    "type": "string",
                    "description": "비밀번호 (8자 이상, 영문 1자 이상 + 숫자 1자 이상 포함, 공백 불허)"
                  },
                  "name": {
                    "type": "string",
                    "description": "사용자 이름"
                  }
                }
              },
              "example": {
                "email": "user@example.com",
                "password": "password123",
                "name": "홍길동"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "회원가입 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "email": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "id": 1,
                  "email": "user@example.com",
                  "name": "홍길동"
                }
              }
            }
          },
          "400": {
            "description": "입력값 오류 (필수 필드 누락 또는 형식 위반)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "missing_field": {
                    "summary": "필수 필드 누락",
                    "value": { "status": 400, "message": "이메일은 필수입니다", "code": "MISSING_FIELD" }
                  },
                  "invalid_format": {
                    "summary": "이메일 형식 오류",
                    "value": { "status": 400, "message": "올바른 이메일 형식이 아닙니다", "code": "INVALID_FORMAT" }
                  },
                  "invalid_password": {
                    "summary": "비밀번호 조건 미충족",
                    "value": { "status": 400, "message": "비밀번호는 8자 이상이며 영문과 숫자를 포함해야 합니다", "code": "INVALID_FORMAT" }
                  }
                }
              }
            }
          },
          "409": {
            "description": "이메일 중복",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 409,
                  "message": "이미 사용 중인 이메일입니다",
                  "code": "EMAIL_DUPLICATE"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "로그인",
        "description": "이메일과 비밀번호로 로그인하여 JWT 토큰을 발급받는다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "이메일"
                  },
                  "password": {
                    "type": "string",
                    "description": "비밀번호"
                  }
                }
              },
              "example": {
                "email": "user@example.com",
                "password": "password123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "로그인 성공. JWT 토큰과 사용자 정보(테마, 언어 포함)를 반환한다.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "description": "JWT 액세스 토큰"
                    },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                },
                "example": {
                  "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                  "user": {
                    "id": 1,
                    "email": "user@example.com",
                    "name": "홍길동",
                    "theme": "light",
                    "language": "ko"
                  }
                }
              }
            }
          },
          "400": {
            "description": "필수 필드 누락",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 400,
                  "message": "이메일은 필수입니다",
                  "code": "MISSING_FIELD"
                }
              }
            }
          },
          "401": {
            "description": "인증 실패 (이메일 또는 비밀번호 불일치)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "이메일 또는 비밀번호가 올바르지 않습니다",
                  "code": "INVALID_CREDENTIALS"
                }
              }
            }
          }
        }
      }
    },
    "/api/users/me": {
      "get": {
        "tags": ["users"],
        "summary": "내 정보 조회",
        "description": "로그인한 사용자의 정보를 조회한다. 테마와 언어 설정을 포함한다.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "내 정보 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                },
                "example": {
                  "id": 1,
                  "email": "user@example.com",
                  "name": "홍길동",
                  "theme": "light",
                  "language": "ko",
                  "created_at": "2026-05-27T00:00:00.000Z"
                }
              }
            }
          },
          "401": {
            "description": "인증 필요",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "인증이 필요합니다",
                  "code": "AUTH_REQUIRED"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["users"],
        "summary": "내 정보 수정",
        "description": "로그인한 사용자의 이름, 비밀번호, 테마, 언어를 수정한다.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "변경할 이름"
                  },
                  "password": {
                    "type": "string",
                    "description": "변경할 비밀번호 (8자 이상, 영문 1자 이상 + 숫자 1자 이상 포함, 공백 불허)"
                  },
                  "theme": {
                    "type": "string",
                    "enum": ["light", "dark"],
                    "description": "변경할 UI 테마"
                  },
                  "language": {
                    "type": "string",
                    "enum": ["ko", "en"],
                    "description": "변경할 UI 언어"
                  }
                }
              },
              "example": {
                "name": "김철수",
                "theme": "dark",
                "language": "en"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "내 정보 수정 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                },
                "example": {
                  "id": 1,
                  "email": "user@example.com",
                  "name": "김철수",
                  "theme": "dark",
                  "language": "en",
                  "created_at": "2026-05-27T00:00:00.000Z"
                }
              }
            }
          },
          "400": {
            "description": "수정 항목 없음 또는 형식 위반",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "missing_field": {
                    "summary": "수정 항목 없음",
                    "value": { "status": 400, "message": "수정할 항목이 없습니다", "code": "MISSING_FIELD" }
                  },
                  "invalid_format": {
                    "summary": "비밀번호 조건 미충족 또는 theme/language 허용값 위반",
                    "value": { "status": 400, "message": "비밀번호는 8자 이상이며 영문과 숫자를 포함해야 합니다", "code": "INVALID_FORMAT" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "인증 필요",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "인증이 필요합니다",
                  "code": "AUTH_REQUIRED"
                }
              }
            }
          }
        }
      }
    },
    "/api/categories": {
      "get": {
        "tags": ["categories"],
        "summary": "내 카테고리 목록 조회",
        "description": "로그인한 사용자의 카테고리 목록을 조회한다. 시스템 공통 기본 카테고리 포함.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "카테고리 목록 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Category"
                  }
                },
                "example": [
                  {
                    "id": 1,
                    "name": "기본",
                    "user_id": null
                  },
                  {
                    "id": 2,
                    "name": "업무",
                    "user_id": 1
                  }
                ]
              }
            }
          },
          "401": {
            "description": "인증 필요",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "인증이 필요합니다",
                  "code": "AUTH_REQUIRED"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["categories"],
        "summary": "카테고리 생성",
        "description": "새 카테고리를 생성한다. 동일 사용자 내 이름 중복은 허용하지 않는다.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "카테고리 이름"
                  }
                }
              },
              "example": {
                "name": "개인"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "카테고리 생성 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Category"
                },
                "example": {
                  "id": 3,
                  "name": "개인",
                  "user_id": 1
                }
              }
            }
          },
          "401": {
            "description": "인증 필요",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "인증이 필요합니다",
                  "code": "AUTH_REQUIRED"
                }
              }
            }
          },
          "400": {
            "description": "name 필드 누락",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 400,
                  "message": "카테고리 이름은 필수입니다",
                  "code": "MISSING_FIELD"
                }
              }
            }
          },
          "409": {
            "description": "카테고리 이름 중복",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 409,
                  "message": "이미 사용 중인 카테고리 이름입니다",
                  "code": "CATEGORY_NAME_DUPLICATE"
                }
              }
            }
          }
        }
      }
    },
    "/api/categories/{id}": {
      "patch": {
        "tags": ["categories"],
        "summary": "카테고리 수정",
        "description": "본인 소유 카테고리의 이름을 수정한다. 기본 카테고리(user_id = NULL)는 수정할 수 없다.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "카테고리 ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "변경할 카테고리 이름"
                  }
                }
              },
              "example": {
                "name": "사이드 프로젝트"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "카테고리 수정 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Category"
                },
                "example": {
                  "id": 2,
                  "name": "사이드 프로젝트",
                  "user_id": 1
                }
              }
            }
          },
          "401": {
            "description": "인증 필요",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "인증이 필요합니다",
                  "code": "AUTH_REQUIRED"
                }
              }
            }
          },
          "400": {
            "description": "name 필드 누락",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 400,
                  "message": "카테고리 이름은 필수입니다",
                  "code": "MISSING_FIELD"
                }
              }
            }
          },
          "403": {
            "description": "수정 권한 없음 (기본 카테고리는 수정 불가, 또는 타인 소유)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "default_category": {
                    "summary": "기본 카테고리 수정 시도",
                    "value": { "status": 403, "message": "기본 카테고리는 수정할 수 없습니다", "code": "FORBIDDEN" }
                  },
                  "not_owner": {
                    "summary": "타인 소유 카테고리 수정 시도",
                    "value": { "status": 403, "message": "해당 카테고리를 수정할 권한이 없습니다", "code": "FORBIDDEN" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "카테고리를 찾을 수 없음",
            "content": {
              "application/json": {
                "schema": {
