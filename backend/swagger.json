    "/api/todos": {
      "get": {
        "tags": ["todos"],
        "summary": "내 할일 목록 조회",
        "description": "로그인한 사용자의 할일 목록을 조회한다. 카테고리, 상태, 기한초과 조건으로 필터링할 수 있다. is_overdue는 조회 시 동적으로 계산된다.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
